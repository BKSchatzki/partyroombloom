# PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/db?schema=public"

# OpenAI
OPENAI_API_KEY=""
# Optional. Defaults to gpt-4o-mini.
OPENAI_MODEL=""

# Site metadata
# Optional. Defaults to https://partyroombloom.vercel.app.
SITE_URL=""

# Google Auth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Must point at this app's /login/google/callback route.
AUTH_GOOGLE_REDIRECT_URI="http://localhost:3000/login/google/callback"

# NPC Service
# Optional. Leave empty to disable the standalone NPC service page.
NEXT_PUBLIC_NPC_SERVICE_URL=""
