{
  "name": "partyroombloom",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "npm run db:generate && next build",
    "start": "node .next/standalone/server.js",
    "lint": "eslint .",
    "typegen": "next typegen",
    "typecheck": "npm run typegen && node scripts/clean-next-dev-types.js && tsc --noEmit",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run build",
    "smoke:production": "node scripts/smoke-production.js",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "lint-staged": "lint-staged",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "node scripts/prepare.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@react-pdf/renderer": "^4.1.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "^5.59.20",
    "arctic": "^3.7.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "dayjs": "^1.11.13",
    "embla-carousel-auto-scroll": "^8.5.2",
    "embla-carousel-react": "^8.2.0",
    "file-saver": "^2.0.5",
    "jotai": "^2.9.3",
    "jotai-family": "^1.0.2",
    "lucide-react": "^0.577.0",
    "next": "^16.2.6",
    "openai": "^6.39.0",
    "prisma": "^6.19.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-pdf-tailwind": "^2.3.0",
    "react-textarea-autosize": "^8.5.3",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "tailwind-animate": "^0.2.10",
    "tailwind-merge": "^2.5.2",
    "tailwind-scrollbar": "^4.0.2",
    "vaul": "^1.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  }
}
